[colors]
background = #cf2d2d2d
background-alt = #363636
foreground = #d3d0c8
primary = #6699cc
secondary = #66cccc
alert = #652566
disabled = #747369

red = #e65256
green = #78cd78
yellow = #ffc85a
blue = #4a8ccd
magenta = #d080d0
cyan = #43cbcb
white = #d3d0c8

bred = #f2777a
bgreen = #99cc99
byellow = #ffcc66
bblue = #6699cc
bmagenta = #cc99cc
bcyan = #66cccc
bwhite = #f2f0ec
trans = #00000000
[bar/mybar]
width = 100%
height = 3.5%
radius = 0

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 3

border-size = 0
border-color = #00000000

padding-left = 1.5
padding-right = 1.5

offset-x = 0
offset-y = 0

module-margin = 1

separator = |
separator-foreground = ${colors.disabled}


font-0=FiraCode Nerd Font:size=12:weight=Bold;0
font-1=Material Design Icons Desktop:size=12;0

modules-left = powermenu xworkspaces xwindow
modules-right =  pulseaudio battery wlan eth filesystem memory cpu  
modules-center =  date

cursor-click = pointer
cursor-scroll = ns-resize

enable-ipc = true
fixed-center= true
#tray-position = right

; wm-restack = generic
; wm-restack = bspwm
; wm-restack = i3
#tray-offset-x = 50
; override-redirect = true

[module/networkwrapper]
type = custom/script
exec = ~/.config/polybar/networkwrapper/networkwrapper.rb

tail = true

interval = 1

[module/xworkspaces]
type = internal/xworkspaces

label-active = %name%
label-active-foreground = ${colors.green}
#label-active-background = ${colors.blue}
#label-active-underline= ${colors.blue}
label-active-padding = 1

label-occupied = %name%
label-occupied-padding = 1
label-occupied-foreground = ${colors.bblue}

label-urgent = %name%
label-urgent-background = ${colors.alert}
label-urgent-padding = 1

label-empty = %name%
label-empty-foreground = ${colors.blue}
label-empty-padding = 1

[module/xwindow]
type = internal/xwindow
label = %title:0:60:...%
[module/filesystem]
type = internal/fs
interval = 25

mount-0 = /

;label-mounted = %{F#F0C674}%mountpoint%%{F-} %percentage_used%%

label-mounted-foreground = ${colors.magenta}
label-mounted = ÔüČ %percentage_used%%

label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.disabled}

[module/powermenu]
type = custom/menu

format-spacing = 1

label-open = ÔÄĎ 
label-open-foreground = ${colors.red}
label-close =  cancel
label-close-foreground = ${colors.red}
label-separator = |
label-separator-foreground = ${colors.foreground-alt}

menu-0-0 = Ô•í reboot
menu-0-0-exec = menu-open-1
menu-0-0-foreground = ${colors.yellow}
menu-0-1 = Ôģ£ power off
menu-0-1-foreground = ${colors.green}
menu-0-1-exec = menu-open-2
menu-0-2-foreground = ${colors.blue}
menu-0-2 = ‚Źĺ log out
menu-0-2-exec = menu-open-3

menu-1-0 = back
menu-1-0-exec = menu-open-0
menu-1-1-foreground = ${colors.yellow}
menu-1-1 =Ô•í confirm
menu-1-1-exec = systemctl reboot

menu-2-0 = back
